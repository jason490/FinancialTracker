FROM golang:1.26-alpine AS builder

RUN apk add --no-cache gcc musl-dev sqlite-dev

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 go build -ldflags="-s -w" -o /main main.go

FROM alpine:3.21

RUN apk add --no-cache ca-certificates sqlite-libs

WORKDIR /app

COPY --from=builder /main /app/main
COPY database/schema.sql /app/database/schema.sql

ENV PORT=8080
ENV DATABASE_PATH=/data/main.db
ENV ENV=production

EXPOSE 8080

CMD ["/app/main"]
