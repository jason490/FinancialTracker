# Copy to .env and fill in before: make prod-build && make prod-up
#
# Public hostname and URLs (must match how users reach the app through Caddy).
# SITE_HOST is the bare domain Caddy listens on; use https:// in the URL vars below.
SITE_HOST=yourdomain.com
API_PUBLIC_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Auth
ENCRYPTION_KEY=replace-with-32-byte-secret-key!!
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Subscriptions (set false to disable Stripe billing and usage limits)
SUBSCRIPTIONS_ENABLED=false

# Plaid (default bank provider)
FINANCIAL_PROVIDER=plaid
PLAID_CLIENT_ID=
PLAID_ENV=production
PLAID_PROD_SECRET=
PLAID_WEBHOOK_URL=

# Stripe billing
STRIPE_PROD_SECRET=
STRIPE_PUBLISHABLE=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PREMIUM=
STRIPE_WEBHOOK_SECRET=

# Email (required for password reset)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

# Optional per-user overrides
# SUBSCRIPTION_OVERRIDES=you@example.com=unlimited,coupon=FRIENDS50
