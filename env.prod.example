# Copy to .env and fill in before: make prod-build && make prod-up
#
# Build-time vs runtime (remote VPS deploy):
# - Local build machine: API_PUBLIC_URL and FRONTEND_URL must match production (baked into the frontend image).
#   Secrets are not required to build images.
# - VPS: copy a full .env here with all secrets; containers read it at startup (not baked into images).
#   Rebuild and redeploy images after changing API_PUBLIC_URL or FRONTEND_URL.
#
# --- Domain (replace yourdomain.com with your real hostname) ---
# SITE_HOST: bare hostname Caddy uses for TLS (no https://)
# API_PUBLIC_URL / FRONTEND_URL: full public URLs (must use https:// and match SITE_HOST)
SITE_HOST=yourdomain.com
API_PUBLIC_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
# Recommended for Let's Encrypt expiry/security notices (Caddy works without it, but set this)
ACME_EMAIL=admin@yourdomain.com

# Auth
ENCRYPTION_KEY=replace-with-32-byte-secret-key!!
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Subscriptions (set false to disable Stripe billing and usage limits)
SUBSCRIPTIONS_ENABLED=false

# Invite-only registration when subscriptions are disabled
# REGISTRATION_ADMIN_EMAILS=admin@yourdomain.com

# Plaid (default bank provider)
FINANCIAL_PROVIDER=plaid
PLAID_CLIENT_ID=
PLAID_ENV=production
PLAID_PROD_SECRET=
PLAID_WEBHOOK_URL=

# Stripe billing
STRIPE_PROD_SECRET=
STRIPE_PUBLISHABLE=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PREMIUM=
STRIPE_WEBHOOK_SECRET=

# Email (required for password reset)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

# Optional per-user overrides
# SUBSCRIPTION_OVERRIDES=you@example.com=unlimited,coupon=FRIENDS50
