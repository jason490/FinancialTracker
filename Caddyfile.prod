{
    admin off
    email {$ACME_EMAIL}
}

# SITE_HOST should be a bare hostname (e.g. yourdomain.com). Caddy provisions TLS
# automatically via Let's Encrypt and redirects HTTP to HTTPS.
{$SITE_HOST} {
    handle /api/* {
        reverse_proxy backend:8080
    }

    handle /api {
        reverse_proxy backend:8080
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    encode gzip

    log {
        output stdout
    }
}
